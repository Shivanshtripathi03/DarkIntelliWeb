# DarkIntelliWeb Environment Configuration
# Copy this file to .env and fill in your values

# MongoDB
MONGO_URI=mongodb://mongodb:27017

# Redis
REDIS_URI=redis://redis:6379

# Tor Proxy
TOR_PROXY_URL=socks5://tor:9050
TOR_CONTROL_HOST=tor
TOR_CONTROL_PORT=9051

# Enrichment API Keys (leave blank to skip enrichment)
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
IPINFO_API_KEY=

# Autonomous AI Triage (optional)
ANTHROPIC_API_KEY=

# Backend
BACKEND_API_URL=http://backend:8000
